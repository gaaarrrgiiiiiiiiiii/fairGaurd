# ============================================================
# FairGuard — Root Environment Template
# Copy → .env and fill in values. NEVER commit .env.
# ============================================================

# ── Security (REQUIRED in production) ────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY_HOURS=24

# ── Tenant API Keys (REQUIRED) ───────────────────────────────
# JSON map: {"<api_key>": "<tenant_id>", ...}
# Generate: python -c "import secrets; print('sk_fgt_' + secrets.token_hex(16))"
FAIRGUARD_API_KEYS={}

# Dev-mode bypass (true = local dev only, false = production)
# When true, unauthenticated requests are accepted as tenant_local_dev.
FAIRGUARD_DEV_MODE=false

# ── Database ─────────────────────────────────────────────────
# SQLite (dev): sqlite:///./fairguard.db
# PostgreSQL (prod): postgresql://user:password@host:5432/fairguard
DATABASE_URL=sqlite:///./fairguard.db

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM Providers (all optional — system degrades gracefully) ─
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── Frontend ─────────────────────────────────────────────────
# Backend API URL (used in docker-compose and frontend .env)
VITE_API_BASE_URL=http://localhost:8000

# JWT obtained from POST /v1/auth/token — leave empty if DEV_MODE=true
VITE_API_TOKEN=
