# ========================================
# FairGuard — Root Environment Variables
# Copy this file to .env and fill in your values.
# Also copy backend/.env.example → backend/.env
# ========================================

# ── Security (REQUIRED in production) ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY_HOURS=24

# ── API Keys for tenant authentication (REQUIRED) ───────────────────────────
# JSON object: {"<raw_api_key>": "<tenant_id>", ...}
# Example: {"sk_fgt_abc123def456": "tenant_acme"}
# Generate a key: python -c "import secrets; print('sk_fgt_' + secrets.token_hex(16))"
FAIRGUARD_API_KEYS={}

# Dev-mode bypass — set to "true" ONLY for local development.
# When true, unauthenticated requests are accepted as tenant_local_dev.
# NEVER set to true in production.
FAIRGUARD_DEV_MODE=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./fairguard.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/fairguard

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM Providers (at least one recommended) ─────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
