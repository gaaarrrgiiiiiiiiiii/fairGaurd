# ============================================
# FairGuard Frontend — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# Auth token (Bearer JWT from POST /v1/auth/token, OR a raw API key)
# Leave empty if FAIRGUARD_DEV_MODE=true is set on the backend
VITE_API_TOKEN=
