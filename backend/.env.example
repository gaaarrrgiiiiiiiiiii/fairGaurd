# ========================================
# FairGuard Backend — Environment Variables
# Copy this file to .env and fill in your values
# ========================================

# ── App ─────────────────────────────────
APP_NAME=FairGuard
API_V1_STR=/v1

# ── Security (REQUIRED in production) ───
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRY_HOURS=24

# ── API Keys (REQUIRED) ──────────────────
# JSON object mapping raw API keys to tenant IDs.
# Example: {"sk_fgt_abc123": "tenant_acme", "sk_fgt_xyz789": "tenant_beta"}
# Generate keys with: python -c "import secrets; print('sk_fgt_' + secrets.token_hex(16))"
FAIRGUARD_API_KEYS={}

# Set to "true" ONLY for local development — bypasses auth enforcement.
# NEVER set to true in production.
FAIRGUARD_DEV_MODE=false

# ── Database ─────────────────────────────
# SQLite (default — fine for dev/demo):
DATABASE_URL=sqlite:///./fairguard.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/fairguard

# ── CORS ─────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── LLM Providers (at least one recommended for richer explanations) ──────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
